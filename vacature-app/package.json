{
  "name": "vacature-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "generate-env": "node scripts/generate-env.js",
    "build": "ng build",
    "build:prod": "node scripts/generate-env.js && ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "test:coverage": "ng test --watch=false --coverage",
    "sonar:local": "npm run test:coverage && node scripts/sonar-local.mjs",
    "sonar:scan:local": "node scripts/sonar-local.mjs",
    "start:e2e": "ng serve --configuration e2e",
    "cypress:open": "cypress open --e2e --browser electron",
    "cypress:run": "cypress run --e2e --browser electron",
    "e2e": "start-server-and-test start:e2e http://localhost:4200 cypress:run",
    "e2e:open": "start-server-and-test start:e2e http://localhost:4200 cypress:open",
    "serve:ssr:vacature-app": "node dist/vacature-app/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "@angular/animations": "^21.2.17",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.16",
    "express": "^5.1.0",
    "keycloak-js": "^26.2.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.16",
    "@angular/cli": "^21.2.16",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@vitest/coverage-v8": "^4.1.9",
    "cypress": "^15.17.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "start-server-and-test": "^3.0.11",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
