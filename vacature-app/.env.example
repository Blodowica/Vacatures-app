# Copy this file to .env and fill in real values.
# Then run:  node scripts/generate-env.js
# This generates src/environments/environment.prod.ts for the production build.
# Never commit .env or environment.prod.ts to git.

KEYCLOAK_URL=https://your-keycloak-server.example.com
KEYCLOAK_REALM=vacature-app
KEYCLOAK_CLIENT_ID=vacature-frontend
